// アプリ全体のカラーパレットとタイポグラフィ定義（テーマ基盤）。
//
// 設計意図（ジュニア向けメモ）:
// * 色・フォントをここに集約し、各コンポーネントへの直書きを排除する。
//   こうすると将来のテーマ変更（色の差し替え・カスタムテーマ追加）が 1 ファイルで済む。
// * `dark-mode` は Windows のシステムテーマ（`Palette.color-scheme`）に既定で追従しつつ、
//   トグルボタンで手動上書きもできるよう `in-out` にしている。
//   （Rust から set すると追従バインディングは上書きされ、以後は手動値が優先される）
// * 配色は Catppuccin（Mocha/Latte 系）を参考にした、長時間でも目に優しいトーン。
//
// 各色は `out`（読み取り専用の派生値）にして、参照側からは書き換えられないようにする。
import { Palette } from "std-widgets.slint";

// タイポグラフィ定数（フォントファミリー・サイズ・ウェイト）。
//
// 設計意図（ジュニア向けメモ）:
// * フォント設定を一箇所にまとめることで、将来のフォント差し替えが容易になる。
// * サイズ列・更新日時列にはモノスペースフォントを使い、桁が縦に揃うようにする。
//   フォールバック順: Cascadia Code（Windows Terminal 付属）→ Consolas（Windows 標準等幅）
//   → monospace（OS の既定等幅フォント）。
// * `ui-font` は Segoe UI 相当の可変幅 UI フォント（ファイル名など）。
// * ウェイト定数は int で定義し、Text.font-weight へ直接代入できるようにする。
export global Typography {
    // UI フォント: ファイル名などの可変幅テキストに使う（Windows 標準 Segoe UI 相当）。
    out property <string> ui-font: "Segoe UI, sans-serif";
    // モノスペースフォント: サイズ・更新日時列の桁揃えに使う。
    out property <string> mono-font: "Cascadia Code, Consolas, monospace";
    // 本文サイズ（行テキスト全般）。
    out property <length> body-size: 13px;
    // ヘッダサイズ（列ヘッダのラベル）。
    out property <length> header-size: 12px;
    // フォントウェイト定数（数値で指定するため int で定義）。
    out property <int> regular: 400;
    out property <int> medium: 500;
    out property <int> bold: 600;
}

export global Theme {
    // 起動時はシステムのカラースキームに追従。トグルで上書き可能。
    in-out property <bool> dark-mode: Palette.color-scheme == ColorScheme.dark;

    // 画面全体の背景。
    out property <brush> background: dark-mode ? #1e1e2e : #ffffff;
    // パネルやヘッダなど、背景から一段持ち上げた面。
    out property <brush> surface: dark-mode ? #313244 : #f3f4f6;
    // 一覧の交互カラー（奇数行）に使う、背景にごく近い面。
    out property <brush> surface-alt: dark-mode ? #262636 : #fafbfc;
    // ヘッダ行など、surface より少しだけ強調した面（モダンヘッダの背景に使う）。
    out property <brush> surface-variant: dark-mode ? #2a2a3d : #f0f1f5;
    // 列間・ヘッダ下などの 1px 区切り線色。
    out property <brush> divider: dark-mode ? #393952 : #d8dae0;
    // 主たる文字色（背景・surface の上に乗る前景）。
    out property <brush> on-surface: dark-mode ? #cdd6f4 : #1e1e2e;
    // 補助的な文字色（サイズ・日時など控えめに見せたい情報）。
    out property <brush> on-surface-variant: dark-mode ? #a6adc8 : #6c7086;
    // 枠線・区切り線。
    out property <brush> border: dark-mode ? #45475a : #e2e4e8;
    // アクセント（ソート方向インジケータなど）。
    out property <brush> accent: #89b4fa;
    // ホバー時の行背景。
    out property <brush> hover: dark-mode ? #45475a : #e8f0fe;
    // 選択中の行背景。
    out property <brush> selection: dark-mode ? #585b70 : #cfe0ff;
    // エラー表示（ステータスバーの文字・背景）。
    out property <brush> error: #f38ba8;
}
