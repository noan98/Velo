import { ListView, Button, HorizontalBox, VerticalBox, LineEdit } from "std-widgets.slint";

// 一覧の 1 行ぶんの「表示用」データ。
// 整形済みの文字列だけを持ち、パス等の真実の源は Rust 側に置く（表示専用）。
export struct FileRow {
    // 種別を表す記号（後でアイコン画像に差し替え可能なよう、まずはテキスト）。
    type-label: string,
    name: string,
    size: string,
    modified: string,
    // 行のスタイル分け等に使えるよう保持（パスは持たない）。
    is-dir: bool,
}

export component MainWindow inherits Window {
    title: "Velo";
    preferred-width: 960px;
    preferred-height: 640px;
    min-width: 480px;
    min-height: 320px;

    // ---- Rust から流し込む状態（表示専用）----
    in property <string> current-path;
    in property <[FileRow]> rows;
    in property <bool> loading;
    // アドレスバーの編集テキスト（双方向）。確定や移動のたびに Rust 側が現在パスへ更新する。
    in-out property <string> address-bar-text;
    // 入力されたパスが解決できなかったときに true。アドレスバーを赤く縁取りして知らせる。
    in-out property <bool> address-error;
    // 検索バーの絞り込み文字列（双方向）。移動時に Rust 側が空へ戻す。
    in-out property <string> filter-text;

    // ---- UI からの操作を Rust へ伝えるコールバック ----
    // 引数は rows 内のインデックス。実際のパス解決は Rust 側で行う。
    callback row-double-clicked(int);
    callback go-up();
    // アドレスバーで Enter が押されたとき、入力文字列を渡してパス解決を依頼する。
    callback path-submitted(string);
    // 検索バーの入力が変わるたびに、現在の絞り込み文字列を渡す。
    callback filter-changed(string);

    VerticalBox {
        padding: 6px;
        spacing: 6px;

        // ツールバー：上へボタン + 編集可能アドレスバー + 検索バー + 読み込み表示
        HorizontalBox {
            vertical-stretch: 0;
            spacing: 8px;
            Button {
                text: "↑ 上へ";
                clicked => { root.go-up(); }
            }

            // アドレスバー（編集可能）。Enter で入力パスへジャンプを依頼する。
            // エラー時は赤枠で縁取り、フォーカスを失ったら現在パスへ戻す（編集キャンセル）。
            Rectangle {
                horizontal-stretch: 1;
                border-width: root.address-error ? 1px : 0px;
                border-color: #d33;
                border-radius: 4px;
                LineEdit {
                    width: parent.width;
                    placeholder-text: "パスを入力して Enter";
                    text <=> root.address-bar-text;
                    accepted(text) => { root.path-submitted(text); }
                    // フォーカス喪失＝編集キャンセル: 現在パスへ戻し、エラー表示も消す。
                    changed has-focus => {
                        if (!self.has-focus) {
                            root.address-bar-text = root.current-path;
                            root.address-error = false;
                        }
                    }
                }
            }

            // 検索バー: 入力のたびに現在ディレクトリ内をインクリメンタルに絞り込む。
            LineEdit {
                width: 220px;
                placeholder-text: "🔍 フィルター...";
                text <=> root.filter-text;
                edited(text) => { root.filter-changed(text); }
            }

            if root.loading: Text {
                text: "読み込み中…";
                color: #888;
                vertical-alignment: center;
            }
        }

        // ヘッダ行（固定）。列幅は下のデータ行と揃える。
        HorizontalBox {
            vertical-stretch: 0;
            padding-left: 8px;
            padding-right: 8px;
            spacing: 8px;
            Text { text: "種別"; width: 48px; font-weight: 700; }
            Text { text: "名前"; horizontal-stretch: 1; font-weight: 700; }
            Text { text: "サイズ"; width: 110px; horizontal-alignment: right; font-weight: 700; }
            Text { text: "更新日時"; width: 150px; font-weight: 700; }
        }

        // 仮想化された一覧。可視範囲の行だけが実体化されるので大量件数でも軽い。
        ListView {
            vertical-stretch: 1;
            for row[idx] in root.rows: Rectangle {
                height: 26px;
                background: touch.has-hover ? #e8f0fe : transparent;

                touch := TouchArea {
                    // フォルダはダブルクリックで中に入る。
                    // この行の rows 内インデックスを Rust に渡し、パス解決は Rust 側で行う。
                    double-clicked => { root.row-double-clicked(idx); }
                }

                HorizontalBox {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    Text {
                        text: row.type-label;
                        width: 48px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: row.name;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    Text {
                        text: row.size;
                        width: 110px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        color: #555;
                    }
                    Text {
                        text: row.modified;
                        width: 150px;
                        vertical-alignment: center;
                        color: #555;
                    }
                }
            }
        }
    }
}
